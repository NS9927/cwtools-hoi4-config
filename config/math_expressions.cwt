alias[math_statement:clamp] = {
	## cardinality = ~1..1
	min = mtth:<mtth>
	min = value[variable]
	min = value[constant]
	min = variable_field
	min = scope_field
	min = scalar
	min = single_alias_right[math_expression]
	## cardinality = ~1..1
	max = mtth:<mtth>
	max = value[variable]
	max = value[constant]
	max = variable_field
	max = scope_field
	max = scalar
	max = single_alias_right[math_expression]
}

alias[math_statement:if] = {
	## cardinality = ~1..1
	limit = single_alias_right[math_expression]
	## cardinality = 0..inf
	alias_name[math_statement] = alias_match_left[math_statement]
}

alias[math_statement:else] = {
	## cardinality = 0..inf
	alias_name[math_statement] = alias_match_left[math_statement]
}

## push_scope = any
alias[math_statement:every_collection] = {
	named_collection = <collection>
	named_collection = collection:<collection>
	named_collection = enum[built_in_collections]
	## cardinality = 0..inf
	alias_name[math_statement] = alias_match_left[math_statement]
}
