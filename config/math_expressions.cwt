single_alias[math_expression] = {
	## cardinality = ~1..1
	value = mtth:<mtth>
	value = value[variable]
	value = value[constant]
	value = variable_field
	value = scope_field
	value = scalar
	## cardinality = 0..inf
	alias_name[math_statement] = alias_match_left[math_statement]
}

alias[math_statement:multiply] = mtth:<mtth>
alias[math_statement:multiply] = value[variable]
alias[math_statement:multiply] = value[constant]
alias[math_statement:multiply] = variable_field
alias[math_statement:multiply] = scope_field
alias[math_statement:multiply] = scalar
alias[math_statement:multiply] = single_alias_right[math_expression]
